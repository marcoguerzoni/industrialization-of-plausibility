# Copy this file to .env and fill in your keys. Never commit .env.

OPENAI_API_KEY=sk-...
TOGETHER_API_KEY=...
MISTRAL_API_KEY=...

# Model identifiers (pin exact versions for reproducibility)
GPT4O_MODEL=gpt-4o-2024-08-06
LLAMA_MODEL=meta-llama/Llama-3-70b-chat-hf
MISTRAL_MODEL=mistral-large-latest

# Embedding models
OPENAI_EMBED_MODEL=text-embedding-3-large
E5_EMBED_MODEL=intfloat/e5-large-v2

# Experiment settings
TEMPERATURE_DEFAULT=0.7
N_RESPONSES_DEFAULT=20
RANDOM_SEED=42
